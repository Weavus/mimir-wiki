# LLM providers are disabled by default.
#
# Copy this file to .env and populate only when running live LLM tasks.
# .env is ignored by git. Keep mimir-wiki.yaml limited to the *_ENV variable
# names, not the secret values themselves.

# Optional runtime overrides.
MIMIR_WIKI_PROVIDER=
MIMIR_WIKI_LLM_ENABLED=

# OpenAI.
OPENAI_API_KEY=

# Azure OpenAI.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# Azure AI Foundry.
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_DEPLOYMENT=

# OpenAI-compatible chat completions endpoint.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
